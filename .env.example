# Feishu bot notification (optional — leave empty to disable notifications)
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
FEISHU_SECRET=your-secret-key

# LLM for idle classification (optional — keyword-only without these)
# Primary endpoint
WATCHDOG_LLM_API_KEY=
WATCHDOG_LLM_BASE_URL=https://api.anthropic.com
WATCHDOG_LLM_MODEL=claude-haiku-4-5-20251001
WATCHDOG_LLM_FORMAT=anthropic

# Fallback endpoint (optional — used when primary fails)
WATCHDOG_LLM_API_KEY_2=
WATCHDOG_LLM_BASE_URL_2=https://open.bigmodel.cn/api/coding/paas/v4
WATCHDOG_LLM_MODEL_2=GLM-4.7
WATCHDOG_LLM_FORMAT_2=openai
